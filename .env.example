# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# Database engine: "postgres" (default/strict) or "sqlite" (local fallback)
DB_ENGINE=sqlite

# PostgreSQL settings (used when DB_ENGINE=postgres)
DB_NAME=togo_rail
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# Email (leave EMAIL_HOST empty to use the console backend in dev)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
CONTACT_EMAIL=contact@togorail.tg
DEFAULT_FROM_EMAIL=Togo Rail <no-reply@togorail.tg>

# Absolute URL building (sitemap, Open Graph)
SITE_DOMAIN=127.0.0.1:8000
SITE_PROTOCOL=http
